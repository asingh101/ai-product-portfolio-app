rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Admin write for site assets
    match /site/{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.email == "ankit.singh101@gmail.com";
    }

    // Admin write for CMS content
    match /projects/{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.email == "ankit.singh101@gmail.com";
    }

    match /events/{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.email == "ankit.singh101@gmail.com";
    }

    match /blog/{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.email == "ankit.singh101@gmail.com";
    }

    match /gallery/{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.email == "ankit.singh101@gmail.com";
    }

    match /chat_assets/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
